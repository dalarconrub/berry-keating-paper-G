\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Bounds on character sums: the key input for all algorithmic consequences. GRH provides the strongest bound, which directly yields the sharpest complexity estimates. The gap between GRH and unconditional bounds translates into the gap between the algorithmic results in Sections~\ref {sec:miller}--\ref {sec:generators}.}}{2}{table.1}\protected@file@percent }
\newlabel{tab:charsums}{{1}{2}{Bounds on character sums: the key input for all algorithmic consequences. GRH provides the strongest bound, which directly yields the sharpest complexity estimates. The gap between GRH and unconditional bounds translates into the gap between the algorithmic results in Sections~\ref {sec:miller}--\ref {sec:generators}}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Quantitative improvement from GRH for a 100-digit number. The GRH bounds are \emph  {polynomial in $\log q$} (efficient), while the unconditional bounds are \emph  {polynomial in $q$} (intractable for large $q$).}}{2}{table.2}\protected@file@percent }
\newlabel{tab:improvement}{{2}{2}{Quantitative improvement from GRH for a 100-digit number. The GRH bounds are \emph {polynomial in $\log q$} (efficient), while the unconditional bounds are \emph {polynomial in $q$} (intractable for large $q$)}{table.2}{}}
