\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces (a)~Number of witnesses required by Miller's deterministic test as a function of the number of digits of~$n$. For a 100-digit number: $\sim 10^5$ witnesses. For RSA-2048 ($\sim 617$ digits): $\sim 4 \times 10^6$. (b)~Comparison of bit operation counts for AKS vs Miller deterministic. Miller is faster by a factor of $\sim \log ^{3.5} n$ (green region).}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:witnesses}{{1}{4}{(a)~Number of witnesses required by Miller's deterministic test as a function of the number of digits of~$n$. For a 100-digit number: $\sim 10^5$ witnesses. For RSA-2048 ($\sim 617$ digits): $\sim 4 \times 10^6$. (b)~Comparison of bit operation counts for AKS vs Miller deterministic. Miller is faster by a factor of $\sim \log ^{3.5} n$ (green region)}{figure.1}{}}
